  { id:"mf28", name:"建筑组件 城墙", series:"30MF", category:"场景", price:2200, releaseDate:"2025-06", image:"images/mf28.png", description:"30MF场景组件，城墙模型。用于搭建战斗场景。", related:[], scale:"-", color:"-" },
  { id:"mf29", name:"建筑组件 塔楼", series:"30MF", category:"场景", price:2200, releaseDate:"2025-08", image:"images/mf29.png", description:"30MF场景组件，塔楼模型。", related:[], scale:"-", color:"-" },
  { id:"mf30", name:"进阶装甲（罗萨堡垒卫士）", series:"30MF", category:"配件", price:1100, releaseDate:"2025-06", image:"images/mf30.jpg", description:"罗萨堡垒卫士进阶装甲套件。", related:["mf05"], scale:"-", color:"-" },
];

// ============================================================
// 应用逻辑
// ============================================================
let currentSeries = 'all';
let currentSubCategory = 'all';
let searchQuery = '';
let activeFilter = '';

const grid = document.getElementById('grid');
const stats = document.getElementById('stats');
const subFilters = document.getElementById('subFilters');
const searchInput = document.getElementById('search');
const modalOverlay = document.getElementById('modalOverlay');
const modal = document.getElementById('modal');
const modalHeader = document.getElementById('modalHeader');
const modalBody = document.getElementById('modalBody');
const modalFooter = document.getElementById('modalFooter');

function getCategories(series) {
  const cats = new Set();
  PRODUCTS.forEach(p => {
    if (series === 'all' || p.series === series) cats.add(p.category);
  });
  return Array.from(cats).sort();
}

function renderSubFilters() {
  const cats = getCategories(currentSeries);
  let html = '<div class="sub-chip active" data-cat="all">全部分类</div>';
  cats.forEach(c => {
    html += `<div class="sub-chip" data-cat="${c}">${c}</div>`;
  });
  subFilters.innerHTML = html;
  document.querySelectorAll('.sub-chip').forEach(chip => {
    chip.addEventListener('click', () => {
      document.querySelectorAll('.sub-chip').forEach(c => c.classList.remove('active'));
      chip.classList.add('active');
      currentSubCategory = chip.dataset.cat;
      render();
    });
  });
}

function filterProducts() {
  let result = PRODUCTS;
  if (currentSeries !== 'all') {
    result = result.filter(p => p.series === currentSeries);
  }
  if (currentSubCategory !== 'all') {
    result = result.filter(p => p.category === currentSubCategory);
  }
  if (searchQuery.trim()) {
    const q = searchQuery.toLowerCase();
    result = result.filter(p =>
      p.name.toLowerCase().includes(q) ||
      p.id.toLowerCase().includes(q) ||
      p.category.toLowerCase().includes(q) ||
      p.color.toLowerCase().includes(q) ||
      (p.description && p.description.toLowerCase().includes(q))
    );
  }
  if (activeFilter === 'upcoming') {
    const now = new Date();
    const currentYM = `${now.getFullYear()}-${String(now.getMonth()+1).padStart(2,'0')}`;
    result = result.filter(p => p.releaseDate >= currentYM);
  }
  if (activeFilter === 'accessory') {
    result = result.filter(p => p.category === '配件' || p.category === '场景');
  }
  return result;
}

function formatDate(dateStr) {
  if (!dateStr) return '未知';
  if (dateStr.length === 7) return dateStr.replace('-', '年') + '月';
  if (dateStr.length === 10) {
    const d = new Date(dateStr);
    return `${d.getFullYear()}年${d.getMonth()+1}月${d.getDate()}日`;
  }
  return dateStr;
}

function getSeriesClass(series) {
  if (series === '30MM') return 'badge-mm';
  if (series === '30MS') return 'badge-ms';
  if (series === '30MF') return 'badge-mf';
  return '';
}

function getSeriesColor(series) {
  if (series === '30MM') return 'var(--mm)';
  if (series === '30MS') return 'var(--ms)';
  if (series === '30MF') return 'var(--mf)';
  return '#888';
}

function getPlaceholderEmoji(series) {
  if (series === '30MM') return '&#129302;'; // robot
  if (series === '30MS') return '&#128520;'; // girl
  if (series === '30MF') return '&#9876;'; // sword
  return '&#127912;';
}

function render() {
  const filtered = filterProducts();
  const sorted = filtered.sort((a, b) => a.releaseDate.localeCompare(b.releaseDate));
  
  if (sorted.length === 0) {
    grid.innerHTML = `
      <div class="no-results">
        <div class="no-results-icon">&#128269;</div>
        <p>没有找到匹配的产品</p>
        <p>请尝试其他搜索词或筛选条件</p>
      </div>
    `;
  } else {
    grid.innerHTML = sorted.map(p => `
      <div class="card" onclick="openModal('${p.id}')">
        <div class="card-img-wrap">
          ${p.image ? `<img src="${p.image}" alt="${p.name}" loading="lazy">` : `<div class="placeholder-img">${getPlaceholderEmoji(p.series)}</div>`}
          <div class="series-badge ${getSeriesClass(p.series)}">${p.series}</div>
        </div>
        <div class="card-body">
          <div class="card-name">${p.name}</div>
          <div class="card-meta">
            <div class="card-meta-row">
              <span>${formatDate(p.releaseDate)}</span>
              <span class="card-price">${p.price ? p.price.toLocaleString() + '円' : '价格未知'}</span>
            </div>
            <div class="card-tag">${p.category}${p.scale ? ' · ' + p.scale : ''}</div>
          </div>
        </div>
      </div>
    `).join('');
  }
  
  const total = PRODUCTS.length;
  stats.innerHTML = `共 ${total} 件产品 | 当前显示 ${sorted.length} 件${currentSeries !== 'all' ? ' · ' + currentSeries : ''}${currentSubCategory !== 'all' ? ' · ' + currentSubCategory : ''}${searchQuery ? ' · 搜索: ' + searchQuery : ''}`;
}

function openModal(id) {
  const p = PRODUCTS.find(x => x.id === id);
  if (!p) return;
  
  modalHeader.innerHTML = `
    ${p.image ? `<img src="${p.image}" alt="${p.name}">` : `<div style="display:flex;align-items:center;justify-content:center;height:100%;"><div class="placeholder-img" style="width:100px;height:100px;font-size:2.5rem;">${getPlaceholderEmoji(p.series)}</div></div>`}
    <button class="modal-close" onclick="closeModal()">&times;</button>
  `;
  
  const relatedHtml = p.related && p.related.length > 0
    ? `<div class="modal-section"><h3>关联产品</h3><div class="related-list">${p.related.map(rid => {
        const rp = PRODUCTS.find(x => x.id === rid);
        return rp ? `<div class="related-chip" onclick="openModal('${rp.id}')">${rp.name}</div>` : '';
      }).join('')}</div></div>`
    : '';
  
  modalBody.innerHTML = `
    <div class="modal-title">${p.name}</div>
    <div class="modal-subtitle">${p.id} · ${p.series} · ${p.category}</div>
    <div class="info-grid">
      <div class="info-item"><div class="info-label">发售日期</div><div class="info-value">${formatDate(p.releaseDate)}</div></div>
      <div class="info-item"><div class="info-label">价格</div><div class="info-value">${p.price ? p.price.toLocaleString() + ' 日元' : '未知'}</div></div>
      <div class="info-item"><div class="info-label">系列</div><div class="info-value" style="color:${getSeriesColor(p.series)}">${p.series}</div></div>
      <div class="info-item"><div class="info-label">分类</div><div class="info-value">${p.category}</div></div>
      ${p.scale ? `<div class="info-item"><div class="info-label">比例</div><div class="info-value">${p.scale}</div></div>` : ''}
      ${p.color ? `<div class="info-item"><div class="info-label">配色</div><div class="info-value">${p.color}</div></div>` : ''}
    </div>
    <div class="modal-section"><h3>产品描述</h3><p>${p.description || '暂无描述'}</p></div>
    ${relatedHtml}
  `;
  
  modalFooter.innerHTML = `
    <a href="https://bandaihobbysite.cn/index/index/detail/id/${p.id.replace(/[^0-9]/g,'')}" target="_blank" class="external-link" style="opacity:0.5;pointer-events:none;" onclick="alert('产品链接需要手动更新至对应编号');return false;">
      在万代 Hobby 官网查看 &#8599;
    </a>
  `;
  
  modalOverlay.classList.add('open');
  document.body.style.overflow = 'hidden';
}

function closeModal() {
  modalOverlay.classList.remove('open');
  document.body.style.overflow = '';
}

modalOverlay.addEventListener('click', e => {
  if (e.target === modalOverlay) closeModal();
});

document.addEventListener('keydown', e => {
  if (e.key === 'Escape') closeModal();
});

// Filter chips
document.querySelectorAll('.filter-chip').forEach(chip => {
  chip.addEventListener('click', () => {
    document.querySelectorAll('.filter-chip').forEach(c => c.classList.remove('active'));
    chip.classList.add('active');
    
    if (chip.dataset.series) {
      currentSeries = chip.dataset.series;
      activeFilter = '';
      currentSubCategory = 'all';
      renderSubFilters();
    } else if (chip.dataset.filter) {
      activeFilter = chip.dataset.filter;
      if (activeFilter === 'accessory') currentSeries = 'all';
    }
    render();
  });
});

// Search
searchInput.addEventListener('input', e => {
  searchQuery = e.target.value;
  render();
});

// Initialize
renderSubFilters();
render();
</script>
</body>
</html>
